# Copy to .env and fill in values:
#   cp .env.example .env

# Oracle Database connection
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=ORCLPDB1

# Passwords - change these before first run
ORACLE_PWD=
ORDS_PWD=

# ORDS context path
CONTEXT_ROOT=ords

# TLS (optional - set to true and provide keystore to enable HTTPS on 8443)
ENABLE_TLS=false
TLS_KEYSTORE_PASS=changeit

# Database wait retries (5 seconds between each retry)
DB_WAIT_RETRY=60

# ORDS feature flags
FEATURE_SDW=true
FEATURE_DB_API=true
FEATURE_REST_APEX=false
FEATURE_PLSQL_GATEWAY=false

# Set to true to configure ORDS without starting Tomcat
SETUP_ONLY=false
